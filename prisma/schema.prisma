// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADOPTANT
  ADMIN
}

enum Species {
  CHIEN
  CHAT
  AUTRE
}

enum Sex {
  MALE
  FEMELLE
}

enum Size {
  PETIT
  MOYEN
  GRAND
}

enum Status {
  ATTENTE_VALIDATION
  DISPONIBLE
  ADOPTE
  REJETE
}

enum Temperament {
  CALME
  ACTIF
  TIMIDE
  PLAYFUL
  PROTECTEUR
}

enum HousingType {
  APPARTEMENT
  MAISON
  MAISON_AVEC_JARDIN
}

model Animal {
  id               String        @id @default(uuid())
  name             String
  species          Species
  sex              Sex
  size             Size
  temperament      Temperament
  age              Int?
  description      String?
  vaccinated       Boolean       @default(false)
  spayed           Boolean       @default(false)
  dewormed         Boolean       @default(false)
  breed            String?
  color            String?
  birthDate        DateTime?
  medicalConditions String?
  status           Status        @default(ATTENTE_VALIDATION)
  ownerId          String
  owner            User          @relation(fields: [ownerId], references: [id])
  photos           AnimalPhoto[]
  healthRecords    HealthRecord[]
  adoptionRequests AdoptionRequest[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  rejectedReason   String?
}

model AnimalPhoto {
  id         String  @id @default(uuid())
  animalId   String
  animal     Animal  @relation(fields: [animalId], references: [id])
  url        String
  publicId   String?
  isPrimary  Boolean @default(false)
  createdAt  DateTime @default(now())
}

model HealthRecord {
  id          String    @id @default(uuid())
  animalId    String
  animal      Animal    @relation(fields: [animalId], references: [id])
  title       String
  description String?
  date        DateTime
  veterinarian String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model AdoptionRequest {
  id         String    @id @default(uuid())
  animalId   String
  animal     Animal    @relation(fields: [animalId], references: [id])
  adopterId  String
  adopter    User      @relation(fields: [adopterId], references: [id])
  status     Status    @default(ATTENTE_VALIDATION)
  message    String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String?
  roles        Role[]   @default([ADOPTANT])
  isActive     Boolean  @default(true)
  isBanned     Boolean  @default(false)
  refreshTokens RefreshToken[]
  profile      UserProfile?
  animals      Animal[]
  adoptionRequests AdoptionRequest[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id])
}

model UserProfile {
  id               String      @id @default(uuid())
  userId           String      @unique
  user             User        @relation(fields: [userId], references: [id])
  firstName        String
  lastName         String
  phone            String?
  city             String
  housingType      HousingType
  surfaceArea      Int?
  hasGarden        Boolean
  hasChildren      Boolean
  childrenAges     Int[]
  hasOtherPets     Boolean
  otherPetsDesc    String?
  hoursAbsent      Int
  hasPetExperience Boolean
  petExpDesc       String?
  avatarUrl        String?
}
