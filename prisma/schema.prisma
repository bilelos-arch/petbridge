// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Role {
  ADOPTANT
  DONNEUR
  ADMIN
}

enum Species {
  CHIEN
  CHAT
  AUTRE
}

enum Sex {
  MALE
  FEMELLE
}

enum Size {
  PETIT
  MOYEN
  GRAND
}

enum Temperament {
  CALME
  ACTIF
  TIMIDE
  JOUEUR
  PROTECTEUR
}

enum HousingType {
  APPARTEMENT
  MAISON
  MAISON_AVEC_JARDIN
}

enum AnimalStatus {
  ATTENTE_VALIDATION
  DISPONIBLE
  ADOPTE
  REJETE
}

enum AdoptionStatus {
  EN_ATTENTE
  ACCEPTEE
  REFUSEE
  ANNULEE
  COMPLETEE
}

enum ReportStatus {
  OUVERT
  EN_COURS
  RESOLU
  REJETE
}

enum ReportCible {
  ANIMAL
  UTILISATEUR
  MESSAGE
}

// ─────────────────────────────────────────
// USER
// ─────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String?
  roles         Role[]    @default([ADOPTANT])
  isActive      Boolean   @default(true)
  isBanned      Boolean   @default(false)
  bannedAt      DateTime?
  bannedReason  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  profile          UserProfile?
  animals          Animal[]            @relation("AnimalOwner")
  refreshTokens    RefreshToken[]
  sentMessages     Message[]
  checkIns         CheckIn[]
  adoptantRequests AdoptionRequest[]   @relation("AdoptantRequests")
  donneurRequests  AdoptionRequest[]   @relation("DonneurRequests")
  reports          Report[]            @relation("ReportAuteur")
}

model UserProfile {
  id               String      @id @default(uuid())
  userId           String      @unique
  firstName        String
  lastName         String
  phone            String?
  city             String
  housingType      HousingType
  surfaceArea      Int?
  hasGarden        Boolean     @default(false)
  hasChildren      Boolean     @default(false)
  childrenAges     Int[]
  hasOtherPets     Boolean     @default(false)
  otherPetsDesc    String?
  hoursAbsent      Int
  hasPetExperience Boolean     @default(false)
  petExpDesc       String?
  avatarUrl        String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// ANIMAL
// ─────────────────────────────────────────

model Animal {
  id                String       @id @default(uuid())
  ownerId           String
  originalOwnerId   String
  name              String
  species           Species
  sex               Sex
  size              Size
  temperament       Temperament
  age               Int?
  description       String?
  vaccinated        Boolean      @default(false)
  spayed            Boolean      @default(false)
  dewormed          Boolean      @default(false)
  breed             String?
  color             String?
  birthDate         DateTime?
  medicalConditions String?
  status            AnimalStatus @default(ATTENTE_VALIDATION)
  rejectedReason    String?
  publishedAt       DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  owner            User              @relation("AnimalOwner", fields: [ownerId], references: [id])
  photos           AnimalPhoto[]
  healthRecords    HealthRecord[]
  adoptionRequests AdoptionRequest[]
  reports          Report[]          @relation("ReportAnimal")
}

model AnimalPhoto {
  id        String   @id @default(uuid())
  animalId  String
  url       String
  publicId  String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  animal Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)
}

model HealthRecord {
  id           String   @id @default(uuid())
  animalId     String
  title        String
  description  String?
  date         DateTime
  veterinarian String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  animal Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// ADOPTION
// ─────────────────────────────────────────

model AdoptionRequest {
  id           String         @id @default(uuid())
  animalId     String
  adopterId    String
  donneurId    String
  status       AdoptionStatus @default(EN_ATTENTE)
  message      String?
  decisionNote String?
  decidedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  animal   Animal  @relation(fields: [animalId], references: [id])
  adopter  User    @relation("AdoptantRequests", fields: [adopterId], references: [id])
  donneur  User    @relation("DonneurRequests", fields: [donneurId], references: [id])
  thread   Thread?
}

// ─────────────────────────────────────────
// MESSAGING
// ─────────────────────────────────────────

model Thread {
  id             String   @id @default(uuid())
  adoptionId     String   @unique
  lastActivityAt DateTime @default(now())
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  adoption AdoptionRequest @relation(fields: [adoptionId], references: [id])
  messages Message[]
  checkIns CheckIn[]
}

model Message {
  id        String   @id @default(uuid())
  threadId  String
  senderId  String
  content   String
  mediaUrl  String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  thread   Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender   User     @relation(fields: [senderId], references: [id])
  reports  Report[] @relation("ReportMessage")
}

// ─────────────────────────────────────────
// POST-ADOPTION
// ─────────────────────────────────────────

model CheckIn {
  id        String   @id @default(uuid())
  threadId  String
  userId    String
  note      String?
  photoUrl  String?
  createdAt DateTime @default(now())

  thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])
}

// ─────────────────────────────────────────
// MODERATION
// ─────────────────────────────────────────

model Report {
  id             String       @id @default(uuid())
  authorId       String
  cible          ReportCible
  cibleUserId    String?
  cibleAnimalId  String?
  cibleMessageId String?
  raison         String
  status         ReportStatus @default(OUVERT)
  adminNote      String?
  resolvedAt     DateTime?
  createdAt      DateTime     @default(now())

  author        User      @relation("ReportAuteur", fields: [authorId], references: [id])
  cibleAnimal   Animal?   @relation("ReportAnimal", fields: [cibleAnimalId], references: [id])
  cibleMessage  Message?  @relation("ReportMessage", fields: [cibleMessageId], references: [id])
}